{
  "name": "dataset-loader",
  "version": "1.2.2",
  "description": "SF CLI plugin to load Event Log Files and SObject data into CRM Analytics datasets",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "author": "Sébastien Colladon (colladonsebastien@gmail.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scolladon/dataset-loader.git"
  },
  "license": "MIT",
  "keywords": [
    "sf",
    "sf-plugin",
    "elf",
    "event-log-files",
    "analytics",
    "dataset"
  ],
  "publishConfig": {
    "access": "public"
  },
  "oclif": {
    "commands": "./lib/commands",
    "bin": "sf",
    "topicSeparator": " ",
    "flexibleTaxonomy": true,
    "topics": {
      "dataset": {
        "description": "Dataset loading commands"
      }
    },
    "devPlugins": [
      "@oclif/plugin-help"
    ]
  },
  "knip": {
    "ignoreDependencies": [
      "sinon"
    ],
    "ignoreBinaries": [
      "npm-check-updates"
    ]
  },
  "scripts": {
    "build": "wireit",
    "clean": "wireit",
    "clean:build": "wireit",
    "clean:package-manager": "wireit",
    "compile": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit",
    "lint:staged": "wireit",
    "lint:dependencies": "wireit",
    "lint:duplicates": "wireit",
    "postpack": "shx rm -f oclif.manifest.json && shx sed -i 'blob/v[^/]*/' 'blob/main/' README.md",
    "prepack": "wireit",
    "prepare": "husky",
    "prepublishOnly": "npm shrinkwrap",
    "test": "wireit",
    "test:build": "wireit",
    "test:unit": "wireit",
    "test:unit:coverage": "wireit",
    "test:integration": "wireit",
    "test:mutation": "wireit",
    "test:watch": "vitest",
    "dependencies:upgrade": "npx npm-check-updates -u ; npm install ; npm audit fix",
    "test:perf": "wireit"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "compile",
        "lint"
      ]
    },
    "clean": {
      "command": "shx rm -rf 'reports/*' oclif.manifest.json package.tgz 'dataset-loader-*.tgz' perf-raw.json perf-runtime.json perf-memory.json perf-preview.html",
      "files": [
        "lib",
        "reports/*",
        "oclif.manifest.json",
        "package.tgz",
        "dataset-loader-*.tgz"
      ],
      "dependencies": [
        "clean:build"
      ]
    },
    "clean:build": {
      "command": "shx rm -rf lib",
      "files": [
        "lib/*"
      ]
    },
    "clean:package-manager": {
      "command": "shx rm -rf node_modules tsconfig.tsbuildinfo .wireit",
      "files": [
        "node_modules/*"
      ]
    },
    "compile": {
      "command": "tsc -p . --pretty --incremental",
      "files": [
        "src/**/*.ts",
        "**/tsconfig.json",
        "messages/**"
      ],
      "output": [
        "lib/**",
        "*.tsbuildinfo"
      ],
      "clean": "if-file-deleted"
    },
    "lint": {
      "command": "npx @biomejs/biome check --error-on-warnings --no-errors-on-unmatched src test",
      "files": [
        "src/**",
        "test/**/*.ts",
        "messages/**",
        "**/biome.json",
        "**/tsconfig.json"
      ],
      "output": []
    },
    "lint:fix": {
      "command": "npx @biomejs/biome check --error-on-warnings --no-errors-on-unmatched src test --fix --unsafe",
      "files": [
        "src/**",
        "test/**/*.ts",
        "messages/**",
        "**/biome.json",
        "**/tsconfig.json"
      ],
      "output": []
    },
    "lint:staged": {
      "command": "npx @biomejs/biome check --error-on-warnings --no-errors-on-unmatched --staged src test",
      "files": [
        "src/**",
        "test/**/*.ts",
        "messages/**",
        "**/biome.json",
        "**/tsconfig.json"
      ],
      "output": []
    },
    "lint:dependencies": {
      "command": "knip",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "messages/**",
        "**/tsconfig.json",
        "knip.config.ts"
      ],
      "output": [],
      "dependencies": [
        "lint"
      ]
    },
    "lint:duplicates": {
      "command": "npx jscpd src",
      "files": [
        "src/**/*.ts"
      ],
      "output": [
        "reports/cpd/**"
      ],
      "dependencies": [
        "lint"
      ]
    },
    "prepack": {
      "command": "oclif manifest && oclif readme",
      "files": [
        "src/commands/**/*.ts",
        "messages/**",
        "README.md"
      ],
      "dependencies": [
        "build"
      ],
      "output": [
        "README.md"
      ],
      "clean": false
    },
    "test": {
      "dependencies": [
        "build",
        "lint",
        "test:unit",
        "test:integration"
      ]
    },
    "test:build": {
      "command": "npm install && npm pack && npm run test",
      "dependencies": [
        "clean",
        "clean:package-manager"
      ]
    },
    "test:unit": {
      "command": "vitest run test/unit/",
      "files": [
        "src/**/*.ts",
        "test/unit/**/*.test.ts",
        "vitest.config.ts",
        "tsconfig.json"
      ],
      "output": []
    },
    "test:unit:coverage": {
      "command": "vitest run test/unit/ --coverage",
      "files": [
        "src/**/*.ts",
        "test/unit/**/*.test.ts",
        "vitest.config.ts",
        "tsconfig.json"
      ],
      "output": [
        "coverage/**"
      ]
    },
    "test:integration": {
      "command": "vitest run test/nut/",
      "files": [
        "src/**/*.ts",
        "test/nut/**/*.nut.ts",
        "vitest.config.ts",
        "tsconfig.json"
      ],
      "output": []
    },
    "test:perf": {
      "command": "node --expose-gc ./node_modules/.bin/vitest bench --config vitest.config.perf.ts && node test/perf/formatResults.mjs",
      "files": [
        "src/**/*.ts",
        "test/perf/**",
        "**/tsconfig.json",
        "vitest.config.perf.ts"
      ],
      "output": [
        "perf-raw.json",
        "perf-runtime.json",
        "perf-memory.json"
      ],
      "dependencies": [
        "compile"
      ]
    },
    "test:mutation": {
      "command": "stryker run",
      "dependencies": [
        "lint"
      ],
      "files": [
        "src/**/*.ts",
        "test/unit/**/*.test.ts",
        "vitest.config.ts",
        "stryker.config.mjs",
        "tsconfig.json"
      ],
      "output": [
        "reports/mutation/**"
      ]
    }
  },
  "dependencies": {
    "@salesforce/core": "^8.28.3",
    "@salesforce/sf-plugins-core": "^12.2.6",
    "cli-progress": "^3.12.0",
    "p-limit": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@oclif/plugin-help": "^6.2.44",
    "@salesforce/ts-types": "^2.0.12",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "knip": "^6.6.0",
    "oclif": "^4.23.0",
    "shx": "^0.4.0",
    "sinon": "^21.1.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wireit": "^0.14.12"
  },
  "files": [
    "/lib",
    "/messages",
    "/oclif.manifest.json",
    "/npm-shrinkwrap.json",
    "/oclif.lock"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
