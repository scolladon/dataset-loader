{
  "entries": [
    {
      "name": "pageviews-xrmru",
      "eventLog": "LightningPageView",
      "interval": "Daily",
      "operation": "Overwrite",
      "sourceOrg": "xrmru",
      "targetOrg": "alm-devops",
      "targetDataset": "Test_LightningPageView"
    },
    {
      "name": "pageviews-prod",
      "eventLog": "LightningPageView",
      "interval": "Daily",
      "operation": "Overwrite",
      "sourceOrg": "alm-prod",
      "targetOrg": "alm-devops",
      "targetDataset": "Test_LightningPageView"
    },
    {
      "name": "pageviews-prod-all-file",
      "eventLog": "LightningPageView",
      "interval": "Daily",
      "operation": "Overwrite",
      "sourceOrg": "alm-prod",
      "targetFile": "AllLightningPageView.csv"
    },
    {
      "name": "pageviews-xrmru-all-file",
      "eventLog": "LightningPageView",
      "interval": "Daily",
      "operation": "Overwrite",
      "sourceOrg": "xrmru",
      "targetFile": "AllLightningPageView.csv"
    },
    {
      "name": "pageviews-prod-file",
      "eventLog": "LightningPageView",
      "interval": "Daily",
      "operation": "Overwrite",
      "sourceOrg": "alm-prod",
      "targetFile": "ProdLightningPageView.csv"
    },
    {
      "name": "users-xrmru",
      "sObject": "User",
      "fields": ["Id", "Name", "Username"],
      "operation": "Overwrite",
      "sourceOrg": "xrmru",
      "targetOrg": "alm-devops",
      "targetDataset": "Test_User",
      "augmentColumns": {
        "ORGANIZATION_ID": "{{sourceOrg.Id}}"
      }
    },
    {
      "name": "users-dev",
      "sObject": "User",
      "fields": ["Id", "Name", "Username"],
      "operation": "Overwrite",
      "sourceOrg": "alm-dev",
      "targetOrg": "alm-devops",
      "targetDataset": "Test_User",
      "augmentColumns": {
        "ORGANIZATION_ID": "{{sourceOrg.Id}}"
      }
    },
    {
      "name": "users-xrmru-file",
      "sObject": "User",
      "fields": ["Id", "Name", "Username"],
      "operation": "Overwrite",
      "sourceOrg": "xrmru",
      "targetFile": "XrmruUser.csv",
      "augmentColumns": {
        "ORGANIZATION_ID": "{{sourceOrg.Id}}"
      }
    }
  ]
}
